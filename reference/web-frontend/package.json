{
  "name": "web-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:e2e": "next dev --webpack --hostname 127.0.0.1 --port 3000",
    "build": "next build",
    "start": "next start",
    "build:e2e": "next build",
    "start:e2e": "bunx serve@latest out -l 3000",
    "lint": "eslint .",
    "test": "vitest run",
    "test:affected": "../scripts/test_frontend_affected.sh",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:affected": "../scripts/test_frontend_e2e_affected.sh",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:coverage": "rm -rf .e2e-coverage coverage-e2e && E2E_COVERAGE=1 playwright test",
    "coverage:e2e:report": "node scripts/generate-e2e-coverage.mjs"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.54.0",
    "exceljs": "^4.4.0",
    "idb-keyval": "^6.2.6",
    "js-yaml": "^4.1.1",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-icons": "^5.6.0",
    "react-is": "^19.2.7",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.1.1",
    "monocart-coverage-reports": "^2.12.11",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "overrides": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  }
}
