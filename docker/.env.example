# Copy to `.env` (in docker/) and fill in before `make up` / `make up-cloudflare`.
# docker/.env is git-ignored.

# Trusted public scheme+host used by the BFF to decide the cookie `Secure` flag.
#   Direct mode (make up):            http://localhost:3000  (or http://<lan-ip>:3000)
#   Cloudflare mode (make up-cloudflare): MUST be https://<your-host>
PUBLIC_ORIGIN=

# Direct overlay bind (make up). Loopback by default so a fresh `make up` is not
# silently exposed on the LAN. To serve the LAN, set 0.0.0.0 AND configure your
# firewall deliberately.
WEB_BIND_ADDRESS=127.0.0.1
WEB_PORT=3000

# Cloudflare mode ONLY: the named-tunnel token is read from a Docker SECRET FILE,
# not from this env file. Create docker/secrets/cloudflare-tunnel-token containing
# just the token (Cloudflare Zero Trust > Networks > Tunnels). The tunnel's
# public-hostname origin must point at http://web:3000 (dashboard side). See
# docker/README.md and docs/production-deployment-cloudflare.md.

# --- Backend optimization execution ----------------------------------------------
# Forced-termination grace (seconds) added to a solver's native timeout before the
# watchdog kills the supervised optimization child tree. Positive, finite. Defaults
# to 90; the compose backend passes this value through. Uncomment to override.
#OPTIMIZE_TIMEOUT_GRACE_SECONDS=90

# --- Opt-in public diagnostic (make diagnostic / make diagnostic-memory) ---------
# All optional; the compose `diagnostic` profile already defaults them. Uncomment to
# override. NONE of these affect a normal deployment — the diagnostic profile never
# starts with `make up`/`make up-cloudflare`/`make verify-deploy`.
#
# Target backend. Defaults to the internal backend; set an absolute public origin
# (no path/credentials) to diagnose a real deployment, and run with EXTRA_ARGS=--no-deps.
#DIAGNOSTIC_TARGET_URL=http://backend:8000
# API-path contract: `backend` (default, private unprefixed `/info` + `/optimize/**`)
# or `bff` (same-origin `/api/*`). A public/direct/Cloudflare origin exposes ONLY the
# BFF, so external targeting MUST set this to `bff`.
#DIAGNOSTIC_API_PATH_MODE=backend
# Expected running concurrency — 1 for the reviewed one-worker deployment.
#DIAGNOSTIC_EXPECTED_CONCURRENCY=1
# Upper bound on submitted jobs; defaults to the rebuild's pending capacity (8).
#DIAGNOSTIC_MAX_JOBS=8
#DIAGNOSTIC_INFO_SAMPLES=100
#DIAGNOSTIC_PARALLEL_REQUESTS=10
#DIAGNOSTIC_QUEUE_STABLE_SECONDS=10
#DIAGNOSTIC_WORKFLOW_TIMEOUT_SECONDS=600
#DIAGNOSTIC_JOB_TIMEOUT_SECONDS=3600
