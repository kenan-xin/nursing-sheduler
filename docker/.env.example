# Copy to `.env` (in docker/) and fill in before `make build && docker compose up`.
# docker/.env is git-ignored.

# Cloudflare named-tunnel token (Zero Trust > Networks > Tunnels).
# The tunnel's public-hostname origin must point at http://web:3000 (see runbook).
CLOUDFLARE_TUNNEL_TOKEN=

# Trusted public scheme+host used by the BFF to decide the cookie `Secure` flag.
# Production: https://<your-host>  |  Local HTTP dev: http://localhost:3000
PUBLIC_ORIGIN=
